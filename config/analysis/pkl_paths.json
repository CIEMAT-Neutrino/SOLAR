{
  "_comment": "Central registry of all .pkl files produced and consumed during the SOLAR pipeline. Template variables use {curly_brace} notation — these are NOT Python f-strings but documentation markers. PATH = info['PATH'] = /pnfs/ciemat.es/data/neutrinos/DUNE/SOLAR (from config/{config}/{config}_config.json). DATA_PATHS sub-keys live in analysis/backgrounds.json and are merged into info by load_analysis_info().",

  "INTERMEDIATE": {
    "_comment": "PKL files written by one stage and READ BY ANOTHER for computation (not only for plotting). These must be accessible to all collaborators and therefore live in PNFS.",

    "OSCILLATION_RAW": {
      "description": "High-resolution (raw) oscillation probability templates generated by prob3/nufast backends before rebinning to analysis resolution.",
      "base": "{PATH}/data/OSCILLATION/pkl/raw",
      "filename": "osc_probability_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "full_path": "{PATH}/data/OSCILLATION/pkl/raw/osc_probability_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "written_by": "src/physics/truth/01_process_oscillation.py (pickle.dump, raw DataFrame)",
      "read_by": ["lib/oscillation.py (pd.read_pickle → rebins to OSCILLATION_REBIN)"],
      "path_source": "lib/oscillation.py: path = info['PATH'] + '/data/OSCILLATION/'",
      "in_pnfs": true
    },

    "OSCILLATION_REBIN": {
      "description": "Rebinned oscillation probability templates at analysis resolution (NADIR_BINS × energy bins). Primary input for all sensitivity computations.",
      "base": "{PATH}/data/OSCILLATION/pkl/rebin",
      "filename": "osc_probability_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "full_path": "{PATH}/data/OSCILLATION/pkl/rebin/osc_probability_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "written_by": "lib/oscillation.py (small_df.to_pickle → cached after first rebin of raw template)",
      "read_by": [
        "lib/oscillation.py (pd.read_pickle → cache hit on subsequent loads)",
        "src/physics/sensitivity/01_background_template.py (oscillation-weighted background rates)",
        "src/physics/sensitivity/02_signal_template.py (oscillation-weighted signal rates)"
      ],
      "path_source": "lib/oscillation.py: save_path = info['PATH'] + '/data/OSCILLATION/pkl/rebin/...'",
      "in_pnfs": true
    },

    "BACKGROUND_TRUTH_PDF": {
      "description": "Per-surface normalised momentum PDFs for background particles used by lib/weights.py at event-weighting time.",
      "base": "{DATA_PATHS.TRUTH}/{config}",
      "filename": "{config}_{name}_pdf.pkl",
      "full_path": "{DATA_PATHS.TRUTH}/{config}/{config}_{name}_pdf.pkl",
      "written_by": "src/physics/truth/03_background_pdf.py (save_pkl with truth_path, config, name=None)",
      "read_by": ["lib/weights.py (pickle.load → (hist_s, bins_s) per-surface PDFs)"],
      "path_source": "analysis/backgrounds.json: DATA_PATHS.TRUTH",
      "in_pnfs": true
    },

    "BACKGROUND_TRUTH_EXPOSURE": {
      "description": "Per-surface exposure metadata dict (counts, livetime, geometry) used by lib/weights.py to normalise event rates.",
      "base": "{DATA_PATHS.TRUTH}/{config}",
      "filename": "{config}_{name}_exposure.pkl",
      "full_path": "{DATA_PATHS.TRUTH}/{config}/{config}_{name}_exposure.pkl",
      "written_by": "src/physics/truth/03_background_pdf.py (save_pkl with truth_path, config, name=None)",
      "read_by": ["lib/weights.py (pickle.load → exposure dict keyed by surface_id)"],
      "path_source": "analysis/backgrounds.json: DATA_PATHS.TRUTH",
      "in_pnfs": true
    },

    "BACKGROUND_TRUTH_HISTOGRAMS": {
      "description": "Raw per-surface (surface_id, variable) histograms before PDF normalisation. Optional: consumed by 02_background_spectra.py only when available for PDF-overlay plots.",
      "base": "{DATA_PATHS.TRUTH}/{config}",
      "filename": "{config}_{name}_histograms.pkl",
      "full_path": "{DATA_PATHS.TRUTH}/{config}/{config}_{name}_histograms.pkl",
      "written_by": "src/physics/truth/03_background_pdf.py (save_pkl with truth_path, config, name=None)",
      "read_by": ["src/physics/truth/02_background_spectra.py (optional overlay; only read if file exists)"],
      "path_source": "analysis/backgrounds.json: DATA_PATHS.TRUTH",
      "in_pnfs": true
    },

    "SENSITIVITY_BACKGROUND_TEMPLATE": {
      "description": "Pre-computed background event-rate array for each (NHits, AdjCl, OpHits) cut combination. Avoids re-running full background weighting during best-cut search and significance scan.",
      "base": "{PATH}/SENSITIVITY/{config}/background/{folder}/{energy}",
      "filename": "{config}_background_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}.pkl",
      "full_path": "{PATH}/SENSITIVITY/{config}/background/{folder}/{energy}/{config}_background_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}.pkl",
      "written_by": "src/physics/sensitivity/01_background_template.py (pd.to_pickle via save_df)",
      "read_by": [
        "src/physics/sensitivity/04_best_cuts.py (pd.read_pickle → chi2 optimisation)",
        "src/physics/sensitivity/06_significance.py (pd.read_pickle → background baseline for LLR)"
      ],
      "path_source": "src/physics/sensitivity/01_background_template.py: background_path = info['PATH'] + '/SENSITIVITY/{config}/background/{folder}/{energy}'",
      "in_pnfs": true
    },

    "SENSITIVITY_SIGNAL_TEMPLATE": {
      "description": "Pre-computed signal event-rate array for each (NHits, AdjCl, OpHits) cut × oscillation parameter grid point. Grid spans (sin²θ₁₂, Δm²₂₁) scan range.",
      "base": "{PATH}/SENSITIVITY/{config}/{name}/{folder}/{energy}",
      "filename": "{config}_{name}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "full_path": "{PATH}/SENSITIVITY/{config}/{name}/{folder}/{energy}/{config}_{name}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_dm2_{dm2:.3e}_sin13_{sin13:.3e}_sin12_{sin12:.3e}.pkl",
      "written_by": "src/physics/sensitivity/02_signal_template.py (save_df)",
      "read_by": [
        "src/physics/sensitivity/04_best_cuts.py (pd.read_pickle → chi2 optimisation at best-fit point)",
        "src/physics/sensitivity/06_significance.py (pd.read_pickle → LLR scan)"
      ],
      "path_source": "src/physics/sensitivity/02_signal_template.py: signal_path = info['PATH'] + '/SENSITIVITY/{config}/{name}/{folder}/{energy}'",
      "in_pnfs": true
    },

    "SENSITIVITY_BEST_CUTS": {
      "description": "Best (NHits, AdjCl, OpHits) cut combination row that maximises the sensitivity figure-of-merit. Used by all downstream significance scripts to select the optimal cut.",
      "base": "{PATH}/SENSITIVITY/{folder}/{config}/{name}",
      "filename": "{config}_{name}_highest_SENSITIVITY.pkl",
      "full_path": "{PATH}/SENSITIVITY/{folder}/{config}/{name}/{config}_{name}_highest_SENSITIVITY.pkl",
      "written_by": "src/physics/sensitivity/04_best_cuts.py (save_pkl with path=info['PATH']+'/SENSITIVITY/{folder}', config, name)",
      "read_by": [
        "src/physics/sensitivity/01_background_template.py (_load_best_cut_map → default cut selection)",
        "src/physics/sensitivity/02_signal_template.py (_load_best_cut_map → default cut selection)",
        "src/physics/sensitivity/06_significance.py (pickle.load → best cut row)"
      ],
      "path_source": "src/physics/sensitivity/04_best_cuts.py: save_pkl(path=info['PATH']+'/SENSITIVITY/{folder}', config=args.config, name=args.name)",
      "in_pnfs": true
    },

    "SENSITIVITY_RESULTS": {
      "description": "Significance scan DataFrames over the (sin²θ₁₂, Δm²₂₁) parameter grid. One file per scan axis (solar/reactor × sin12/sin13) plus combined grids. Consumed by all contour and projection plots.",
      "base": "{PATH}/SENSITIVITY/{config}/{name}/{folder}/{energy}/results/{profile}/{signal_condition}",
      "filenames": {
        "solar_sin12": "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_solar_sin12_df.pkl",
        "solar_sin13": "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_solar_sin13_df.pkl",
        "react_sin12": "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_react_sin12_df.pkl",
        "react_sin13": "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_react_sin13_df.pkl",
        "solar":       "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_solar_df.pkl",
        "react":       "{name}_{energy}_NHits{nhits}_AdjCl{adjcl}_OpHits{ophits}_react_df.pkl"
      },
      "written_by": "src/physics/sensitivity/06_significance.py (df.to_pickle for each scan axis)",
      "read_by": [
        "src/physics/sensitivity/projections_plot.py (pd.read_pickle → 1D projections)",
        "src/physics/sensitivity/contour_plot.py (pd.read_pickle → 2D contours)",
        "src/physics/common/significance_plot.py (reads *_df.pkl for combined plots)"
      ],
      "path_source": "src/physics/sensitivity/06_significance.py: path = paths['signal_path'] + '/results/{profile}/{signal_condition}'",
      "in_pnfs": true
    },

    "CALIBRATION_CHARGE": {
      "description": "Charge calibration slope and intercept correction functions (scipy interp1d) for each charge cluster type. Used by lib/cluster.py for event-level charge energy calibration. MOVED FROM config/ TO PNFS so they are shared between collaborators.",
      "base": "{DATA_PATHS.CALIBRATION}/{config}/{name}/calib",
      "filenames": {
        "slope":     "{config}_{variable}charge_slope_calibration.pkl",
        "intercept": "{config}_{variable}charge_intercept_calibration.pkl"
      },
      "full_paths": {
        "slope":     "{DATA_PATHS.CALIBRATION}/{config}/{name}/calib/{config}_{variable}charge_slope_calibration.pkl",
        "intercept": "{DATA_PATHS.CALIBRATION}/{config}/{name}/calib/{config}_{variable}charge_intercept_calibration.pkl"
      },
      "written_by": "src/physics/calibration/02_calibration.py (save_pkl with path=DATA_PATHS.CALIBRATION/{config}/{name}/calib)",
      "read_by": ["lib/cluster.py (pickle.load → calibration functions applied per cluster type)"],
      "path_source": "analysis/backgrounds.json: DATA_PATHS.CALIBRATION",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/config/{config}/{name}/{config}_calib/{config}_{variable}charge_{slope|intercept}_calibration.pkl"
    },

    "CALIBRATION_DISCRIMINANT": {
      "description": "Trained random-forest classifier (sklearn RandomForestClassifier) for signal/background separation. Used by lib/cluster.py to compute per-event discriminant score. MOVED FROM config/ TO PNFS so they are shared between collaborators.",
      "base": "{DATA_PATHS.CALIBRATION}/{config}/{name}/models",
      "filename": "{config}_{name}_random_forest_discriminant.pkl",
      "full_path": "{DATA_PATHS.CALIBRATION}/{config}/{name}/models/{config}_{name}_random_forest_discriminant.pkl",
      "written_by": "src/physics/calibration/03_discrimination.py (pickle.dump)",
      "read_by": ["lib/cluster.py (pickle.load → rf_classifier.predict_proba for discriminant score)"],
      "path_source": "analysis/backgrounds.json: DATA_PATHS.CALIBRATION",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/config/{config}/{name}/models/{config}_{name}_random_forest_discriminant.pkl"
    },

    "SOLAR_BACKGROUND": {
      "description": "Compiled solar background DataFrame (ParticlePDG and ParticleID distributions) for a given config. Consumed by solar_background_plot.py for visualisation.",
      "base": "{PATH}/background/solar/{config}",
      "filename": "{config}_Background.pkl",
      "full_path": "{PATH}/background/solar/{config}/{config}_Background.pkl",
      "written_by": "src/physics/truth/solar_background.py (save_df with path=PATH/background/solar, config=args.config)",
      "read_by": ["src/physics/truth/solar_background_plot.py (pickle.load)"],
      "path_source": "info['PATH'] from config/{config}/{config}_config.json via load_analysis_info()",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/data/background/{config}/{config}_Background.pkl"
    },

    "FIDUCIAL_SCAN": {
      "description": "Per-(config, name, energy, folder) fiducial-volume scan DataFrame. Contains Counts/Energy/FiducializedXYZ per fiducial boundary step. Read by 02_best_fiducial.py and common/significance_plot.py to determine the optimal fiducial volume.",
      "base": "{PATH}/FIDUCIAL/{folder}/{config}/{name}",
      "filename": "{config}_{name}_{energy}_Fiducial_Scan.pkl",
      "full_path": "{PATH}/FIDUCIAL/{folder}/{config}/{name}/{config}_{name}_{energy}_Fiducial_Scan.pkl",
      "written_by": "src/physics/signal/01_fiducialize.py (save_df with path=PATH/FIDUCIAL/{folder}, config, name)",
      "read_by": [
        "src/physics/signal/02_best_fiducial.py (pd.read_pickle → select optimal fiducial volume)",
        "src/physics/common/significance_plot.py (pd.read_pickle in Fiducial mode)"
      ],
      "path_source": "info['PATH'] from load_analysis_info() → PATH/FIDUCIAL/{folder}/{config}/{name}/",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/data/solar/fiducial/{folder}/{config}/{name}/{config}_{name}_{energy}_Fiducial_Scan.pkl"
    },

    "HEP_SIGNIFICANCE": {
      "description": "Per-(config, name, energy, folder) HEP significance and counts DataFrames. Written by hep/significance_plot.py and common/significance_plot.py; consumed by hep/significance_comparison.py, hep/reference_comparison.py, common/exposure_plot.py for multi-config comparison plots.",
      "base": "{PATH}/HEP/{config}/{name}/{folder}",
      "filenames": {
        "significance": "{config}_{name}_HEP_Significance.pkl",
        "counts":       "{config}_{name}_HEP_Counts.pkl",
        "exposure":     "{config}_{name}_HEP_Exposure.pkl"
      },
      "full_paths": {
        "significance": "{PATH}/HEP/{config}/{name}/{folder}/{config}_{name}_HEP_Significance.pkl",
        "counts":       "{PATH}/HEP/{config}/{name}/{folder}/{config}_{name}_HEP_Counts.pkl",
        "exposure":     "{PATH}/HEP/{config}/{name}/{folder}/{config}_{name}_HEP_Exposure.pkl"
      },
      "written_by": [
        "src/physics/hep/significance_plot.py (save_df → HEP_Counts and HEP_Significance)",
        "src/physics/hep/exposure_plot.py (save_df → HEP_Exposure when pkl_label==highest)",
        "src/physics/common/significance_plot.py (save_df → HEP_Counts and HEP_Significance)",
        "src/physics/common/exposure_plot.py (save_df → HEP_Exposure)"
      ],
      "read_by": [
        "src/physics/hep/significance_comparison.py (pd.read_pickle → multi-config significance overlay)",
        "src/physics/hep/reference_comparison.py (pd.read_pickle → HEP_Significance + HEP_Exposure comparison)",
        "src/physics/common/exposure_plot.py (pd.read_pickle → significance and exposure vs exposure curves)"
      ],
      "path_source": "info['PATH'] from load_analysis_info() → PATH/HEP/{config}/{name}/{folder}/",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/data/analysis/hep/{config}/{name}/{folder}/"
    },

    "DAYNIGHT_SIGNIFICANCE": {
      "description": "Per-(config, name, energy, folder) DayNight significance and counts DataFrames. Written by common/significance_plot.py; consumed by common/exposure_plot.py for DayNight exposure curves.",
      "base": "{PATH}/DAYNIGHT/{config}/{name}/{folder}",
      "filenames": {
        "significance": "{config}_{name}_DayNight_Significance.pkl",
        "counts":       "{config}_{name}_DayNight_Counts.pkl"
      },
      "written_by": ["src/physics/common/significance_plot.py (save_df → DayNight_Counts and DayNight_Significance)"],
      "read_by": ["src/physics/common/exposure_plot.py (pd.read_pickle → DayNight exposure curves)"],
      "path_source": "info['PATH'] from load_analysis_info() → PATH/DAYNIGHT/{config}/{name}/{folder}/",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/data/analysis/day-night/{config}/{name}/{folder}/"
    },

    "SENSITIVITY_SIGNIFICANCE": {
      "description": "Per-(config, name, energy, folder) Sensitivity significance and counts DataFrames plus processed contour data. Written by common/significance_plot.py and sensitivity/contour_plot.py; consumed by common/exposure_plot.py and tools/presentations/sensitivity.py.",
      "base": "{PATH}/SENSITIVITY/{config}/{name}/{folder}",
      "filenames": {
        "significance": "{config}_{name}_Sensitivity_Significance.pkl",
        "counts":       "{config}_{name}_Sensitivity_Counts.pkl",
        "contour":      "{config}_{name}_Sensitivity_{energy}.pkl"
      },
      "written_by": [
        "src/physics/common/significance_plot.py (save_df → Sensitivity_Counts and Sensitivity_Significance)",
        "src/physics/sensitivity/contour_plot.py (save_pkl → Sensitivity_{energy})"
      ],
      "read_by": [
        "src/physics/common/exposure_plot.py (pd.read_pickle → Sensitivity exposure curves)",
        "src/tools/presentations/sensitivity.py (pd.read_pickle → Sensitivity_Significance for slide generation)"
      ],
      "path_source": "info['PATH'] from load_analysis_info() → PATH/SENSITIVITY/{config}/{name}/{folder}/",
      "in_pnfs": true,
      "_migration_note": "Previously at {root}/data/analysis/sensitivity/{config}/{name}/{folder}/"
    }
  },

  "OUTPUT_ONLY": {
    "_comment": "PKL files written by a script but never read by any other pipeline script. These are local convenience caches for plotting and can be regenerated at any time. They do NOT need to live in PNFS.",

    "SMEARING_MATRIX": {
      "description": "NHits-resolved energy reconstruction smearing matrix (DataFrame of reco-energy vs true-energy bin fractions). Written once per (config, name, energy, component, NHits) combination. Used only internally by 05_smearing.py for visualisation.",
      "base": "{root}/config/{config}/{name}/{config}_calib",
      "filename": "{config}_{energy}{comp}_Smearing_NHits_{nhit}.pkl",
      "full_path": "{root}/config/{config}/{name}/{config}_calib/{config}_{energy}{comp}_Smearing_NHits_{nhit}.pkl",
      "written_by": "src/physics/calibration/05_smearing.py (smearing_matrix.to_pickle)",
      "read_by": [],
      "in_pnfs": false
    },

    "EVENT_DISPLAY": {
      "description": "Per-event display DataFrame for single-event visualisation tool. Written on demand, never consumed by analysis pipeline.",
      "base": "{output_dir}",
      "filename": "{config}_{name}_event_{evt}_display.pkl",
      "written_by": "src/tools/event_display.py (df.to_pickle)",
      "read_by": [],
      "in_pnfs": false
    }
  }
}
